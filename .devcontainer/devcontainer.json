{
    "name": "ggXu22",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "dev-env",
    "workspaceFolder": "/home/gpadmin/workspace",
    "remoteUser": "gpadmin",
    "postCreateCommand": "if [ ! -d \"greengage\" ]; then git clone https://github.com/GreengageDB/greengage.git; fi",
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh"
            },
            "extensions": [
                "ms-azuretools.vscode-docker",
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.makefile-tools",
                "ash-blade.postgresql-hacker-helper",
                "mhutchie.git-graph"
            ]
        }
    }
}
